{
  "manifest_version": 3,
  "name": "DealHub Assistant",
  "version": "1.3",
  "description": "One-click DealHub AI Assistant — no cookie copying needed.",
  "permissions": ["cookies", "tabs", "sidePanel", "storage", "scripting"],
  "host_permissions": ["*://*.dealhub.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DealHub Assistant"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
